generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
  ACADEMIC
  UNIVERSITY
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum DocumentType {
  COURSEWORK
  THESIS
  ESSAY
  REPORT
  PRESENTATION
}

enum DocumentStatus {
  DRAFT
  GENERATING
  DONE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  plan                  Plan      @default(FREE)
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  planExpiresAt         DateTime?

  accounts          Account[]
  sessions          Session[]
  subscriptions     Subscription[]
  conversations     Conversation[]
  academicDocuments AcademicDocument[]
  documents         Document[]
  usageTracking     UsageTracking[]
  progress          UserProgress?
  quizAttempts      QuizAttempt[]
  presentations     Presentation[]
  knowledgeChunks   KnowledgeChunk[]
  paymentOrders     PaymentOrder[]
  kaspiPaymentRequests KaspiPaymentRequest[]
  promoCodesUsed    PromoCode[]
}

model Ambassador {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  phone            String?
  telegramUsername String?
  refCode          String   @unique
  commission       Int      @default(15)
  totalReferrals   Int      @default(0)
  totalRevenue     Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  referrals        ReferralVisit[]
  paymentRequests  KaspiPaymentRequest[]
}

model ReferralVisit {
  id           String     @id @default(cuid())
  ambassadorId String
  ambassador   Ambassador @relation(fields: [ambassadorId], references: [id])
  visitorIp    String?
  converted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  plan          String
  months        Int       @default(1)
  isUsed        Boolean   @default(false)
  usedByUserId  String?
  usedBy        User?     @relation(fields: [usedByUserId], references: [id])
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
}

model KaspiPaymentRequest {
  id             String      @id @default(cuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])
  ambassadorId   String?
  ambassador     Ambassador? @relation(fields: [ambassadorId], references: [id])
  refCode        String?
  plan           String
  months         Int
  originalAmount Int
  discount       Int         @default(0)
  finalAmount    Int
  customerName   String?
  customerPhone  String?
  status         String      @default("pending")
  promoCodeId    String?
  adminNote      String?
  createdAt      DateTime    @default(now())
  confirmedAt    DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  plan             Plan
  status           SubscriptionStatus @default(ACTIVE)
  stripeCustomerId String?            @unique
  stripeSubId      String?            @unique
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Новый чат")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  agentUsed      String?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AcademicDocument {
  id        String         @id @default(cuid())
  userId    String
  type      DocumentType
  title     String
  content   String?        @db.Text
  status    DocumentStatus @default(DRAFT)
  pages     Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String
  content   Json
  wordCount Int      @default(0)
  pageCount Int      @default(0)
  status    String   @default("draft")
  agentUsed String   @default("writer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Presentation {
  id         String   @id @default(cuid())
  userId     String
  title      String
  slides     Json
  slideCount Int      @default(0)
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KnowledgeChunk {
  id        String   @id @default(cuid())
  userId    String
  sourceId  String
  fileName  String
  chunkText String   @db.Text
  embedding String?  @db.Text
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sourceId])
}

model UsageTracking {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  requestCount Int      @default(0)
  tokensUsed   Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model UserProgress {
  id             String    @id @default(cuid())
  userId         String    @unique
  streak         Int       @default(0)
  lastActiveDate DateTime?
  totalXP        Int       @default(0)
  sessionsCount  Int       @default(0)
  weakTopics     Json      @default("[]")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  topic          String
  score          Int
  totalQuestions Int
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentOrder {
  id         String   @id @default(cuid())
  userId     String
  plan       String
  amount     Int
  currency   String
  provider   String
  status     String   @default("pending")
  externalId String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Waitlist {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  university String?
  createdAt  DateTime @default(now())
}
